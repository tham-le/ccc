CLAUDE_DIR = Path(os.environ.get("CLAUDE_CONFIG_DIR", Path.home() / ".claude"))
PROJECTS_DIR = CLAUDE_DIR / "projects"
HOME = str(Path.home())


def decode_project_dir(dirname: str) -> str:
    """Convert project dir name back to path: -home-user-foo -> /home/user/foo

    The encoding joins path segments with '-', but folder names can also
    contain '-' (e.g. kyber-desktop). We try all possible groupings
    recursively and return the first that matches a real directory.
    """
    parts = dirname.split("-")
    if parts[0] == "":
        parts = parts[1:]

    def _solve(idx: int, built: str) -> str | None:
        if idx == len(parts):
            return built if os.path.isdir(built) else None
        # Try consuming 1..N remaining parts as one segment (joined by '-')
        for end in range(idx + 1, len(parts) + 1):
            segment = "-".join(parts[idx:end])
            candidate = built + "/" + segment
            if os.path.isdir(candidate):
                result = _solve(end, candidate)
                if result is not None:
                    return result
        return None

    return _solve(0, "") or "/" + "/".join(parts)


def _extract_text(content) -> str:
    """Pull plain text from a message content field (str or list of blocks)."""
    if isinstance(content, str):
        return content.strip()
    if isinstance(content, list):
        parts = []
        for block in content:
            if isinstance(block, dict) and block.get("type") == "text":
                parts.append(block.get("text", ""))
            elif isinstance(block, str):
                parts.append(block)
        return "\n".join(parts).strip()
    return ""


def _clean_title(text: str, git_branch: str = "") -> str:
    """Turn a raw first message into a short readable title."""
    t = text.strip()
    # Strip code blocks
    t = re.sub(r"```[\s\S]*?```", "", t)
    # Strip inline code
    t = re.sub(r"`[^`]+`", "", t)
    # Strip markdown headers
    t = re.sub(r"^#{1,6}\s+", "", t, flags=re.MULTILINE)
    # Strip markdown formatting
    t = re.sub(r"\*\*|__|\*|_|~~", "", t)
    # Strip checkboxes
    t = re.sub(r"- \[[ x]\] ", "", t)
    # Strip @file/path mentions
    t = re.sub(r"@[\w~/.\-]+", "", t)
    # Strip URLs
    t = re.sub(r"https?://\S+", "", t)
    # Strip HTML-like tags
    t = re.sub(r"<[^>]+>", "", t)
    # Collapse whitespace
    t = re.sub(r"\s+", " ", t).strip()
    # Take first sentence
    for sep in [". ", "? ", "! ", "\n"]:
        idx = t.find(sep)
        if 10 < idx < 120:
            t = t[:idx + 1]
            break
    # Truncate at word boundary
    if len(t) > 100:
        t = t[:100].rsplit(" ", 1)[0] + "..."
    # Fallback to branch name
    if len(t) < 8 and git_branch:
        # tham/oidc-client-refactor -> oidc client refactor
        branch = git_branch.split("/", 1)[-1] if "/" in git_branch else git_branch
        t = branch.replace("-", " ").replace("_", " ")
    return t.strip() or "(no title)"


def _is_real_message(text: str) -> bool:
    """Filter out slash commands, resume picker output, and other noise."""
    t = text.strip()
    if not t or len(t) < 3:
        return False
    if "<command-name>" in t or "<command-message>" in t:
        return False
    if t.startswith("Resume Session") or t.startswith("\u256d") or t.startswith("\u2502"):
        return False
    if "<local-command-" in t:
        return False
    # Skip skill template expansions (long markdown with headers + checkboxes)
    if len(t) > 800 and "## " in t and "- [ ]" in t:
        return False
    return True


def parse_conversation(jsonl_path: str) -> dict | None:
    """Extract metadata from a conversation JSONL file."""
    try:
        with open(jsonl_path, "r", errors="replace") as f:
            lines = f.readlines()
    except (OSError, IOError):
        return None

    if not lines:
        return None

    session_id = os.path.basename(jsonl_path).replace(".jsonl", "")
    first_user_msg = ""
    first_timestamp = None
    last_timestamp = None
    git_branch = ""
    user_msg_count = 0
    assistant_msg_count = 0
    messages = []

    for line in lines:
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue

        entry_type = entry.get("type")
        ts_raw = entry.get("timestamp")

        if isinstance(ts_raw, str):
            try:
                ts = datetime.fromisoformat(ts_raw.replace("Z", "+00:00"))
            except ValueError:
                ts = None
        elif isinstance(ts_raw, (int, float)):
            try:
                ts = datetime.fromtimestamp(ts_raw / 1000, tz=timezone.utc)
            except (OSError, ValueError):
                ts = None
        else:
            ts = None

        if ts:
            if first_timestamp is None or ts < first_timestamp:
                first_timestamp = ts
            if last_timestamp is None or ts > last_timestamp:
                last_timestamp = ts

        if entry_type == "user":
            user_msg_count += 1
            if not git_branch:
                git_branch = entry.get("gitBranch", "")

            msg = entry.get("message", {})
            content = msg.get("content", "")
            text = _extract_text(content)
            if text and _is_real_message(text):
                if not first_user_msg:
                    first_user_msg = text[:200]
                messages.append({"role": "user", "text": text[:2000]})

        elif entry_type == "assistant":
            assistant_msg_count += 1
            msg = entry.get("message", {})
            content = msg.get("content", [])
            text = _extract_text(content)
            if text:
                messages.append({"role": "assistant", "text": text[:2000]})

    if user_msg_count == 0:
        return None

    size_kb = os.path.getsize(jsonl_path) / 1024

    return {
        "session_id": session_id,
        "first_message": first_user_msg or "(no message)",
        "title": _clean_title(first_user_msg, git_branch) if first_user_msg else "(no message)",
        "first_timestamp": first_timestamp,
        "last_timestamp": last_timestamp,
        "git_branch": git_branch,
        "user_messages": user_msg_count,
        "assistant_messages": assistant_msg_count,
        "size_kb": size_kb,
        "messages": messages[:100],
    }


def scan_all_conversations() -> dict:
    """Scan all project directories for conversations."""
    projects = defaultdict(list)

    if not PROJECTS_DIR.is_dir():
        return projects

    for project_dir in sorted(PROJECTS_DIR.iterdir()):
        if not project_dir.is_dir():
            continue

        project_path = decode_project_dir(project_dir.name)
        jsonl_files = list(project_dir.glob("*.jsonl"))

        for jf in jsonl_files:
            conv = parse_conversation(str(jf))
            if conv:
                conv["project"] = project_path
                projects[project_path].append(conv)

    for proj in projects:
        projects[proj].sort(
            key=lambda c: c["last_timestamp"] or datetime.min.replace(tzinfo=timezone.utc),
            reverse=True,
        )

    return dict(projects)


def generate_html(projects: dict) -> str:
    """Generate self-contained HTML dashboard."""
    all_conversations = []
    project_stats = {}

    for proj_path, convs in projects.items():
        total_msgs = sum(c["user_messages"] for c in convs)
        total_size = sum(c["size_kb"] for c in convs)
        latest = max(
            (c["last_timestamp"] for c in convs if c["last_timestamp"]),
            default=None,
        )
        project_stats[proj_path] = {
            "conversations": len(convs),
            "total_messages": total_msgs,
            "total_size_kb": total_size,
            "latest": latest.isoformat() if latest else None,
        }
        for c in convs:
            all_conversations.append({
                "project": proj_path,
                "session_id": c["session_id"],
                "first_message": c["first_message"],
                "title": c["title"],
                "first_timestamp": c["first_timestamp"].isoformat() if c["first_timestamp"] else None,
                "last_timestamp": c["last_timestamp"].isoformat() if c["last_timestamp"] else None,
                "git_branch": c["git_branch"],
                "user_messages": c["user_messages"],
                "assistant_messages": c["assistant_messages"],
                "size_kb": round(c["size_kb"], 1),
                "messages": c.get("messages", []),
            })

    all_conversations.sort(key=lambda c: c["last_timestamp"] or "0", reverse=True)

    sorted_projects = sorted(
        project_stats.items(),
        key=lambda x: x[1]["latest"] or "0",
        reverse=True,
    )

    def safe_json(obj):
        s = json.dumps(obj, ensure_ascii=True)
        return s.replace("</", "<\\/")

    conversations_json = safe_json(all_conversations)
    projects_json = safe_json([{"path": p, **s} for p, s in sorted_projects])
    home_json = json.dumps(HOME)

    return f"""<!DOCTYPE html>
