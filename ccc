  </div>
  <div class="search-box">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="search" placeholder="Search conversations... (press /)" autocomplete="off">
  </div>
  <div class="stats" id="stats"></div>
  <div class="view-toggle">
    <button id="btn-project" onclick="setView('project')">Projects</button>
    <button id="btn-timeline" onclick="setView('timeline')">Timeline</button>
    <button id="btn-branch" class="active" onclick="setView('branch')">Branches</button>
  </div>
  <button class="theme-btn" id="theme-btn" onclick="toggleTheme()" title="Toggle theme"></button>
</div>

<div class="main">
  <div class="sidebar" id="sidebar"></div>
  <div class="content" id="content"></div>
</div>

<div class="viewer-overlay" id="viewer-overlay" onclick="closeViewer()">
  <div class="viewer" onclick="event.stopPropagation()">
    <div class="viewer-header">
      <h2 id="viewer-title"></h2>
      <button class="viewer-close" onclick="closeViewer()">Esc</button>
    </div>
    <div class="viewer-messages" id="viewer-messages"></div>
  </div>
</div>

<script>
const conversations = {conversations_json};
const projects = {projects_json};
const HOME = {home_json};

let currentView = 'branch';
let currentProject = null;
let searchQuery = '';

function relativeTime(isoStr) {{
  if (!isoStr) return 'unknown';
  const d = new Date(isoStr), now = new Date(), diff = now - d;
  const mins = Math.floor(diff / 60000);
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(diff / 86400000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  if (hours < 24) return hours + 'h ago';
  if (days === 1) return 'yesterday';
  if (days < 7) return days + 'd ago';
  if (days < 30) return Math.floor(days / 7) + 'w ago';
  return d.toLocaleDateString('en-CA');
}}

function shortPath(p) {{
  return p.startsWith(HOME) ? '~' + p.slice(HOME.length) : p;
}}

function projectName(p) {{
  return p.split('/').pop() || p;
}}

function formatSize(kb) {{
  return kb >= 1024 ? (kb / 1024).toFixed(1) + ' MB' : Math.round(kb) + ' KB';
}}

function filterConvs(convs) {{
  if (!searchQuery) return convs;
  const q = searchQuery.toLowerCase();
  return convs.filter(c =>
    (c.first_message || '').toLowerCase().includes(q) ||
    (c.git_branch || '').toLowerCase().includes(q) ||
    (c.project || '').toLowerCase().includes(q)
  );
}}

function esc(s) {{
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}}

const collapsedNodes = new Set();
let allNodeIds = [];

function collectNodeIds(tree, prefix) {{
  for (const [key, node] of Object.entries(tree)) {{
    const fullPath = prefix ? prefix + '/' + key : key;
    if (Object.keys(node._children).length > 0) {{
      allNodeIds.push(fullPath);
      collectNodeIds(node._children, fullPath);
    }}
  }}
}}

function expandAll() {{
  collapsedNodes.clear();
  render();
}}

function collapseAll() {{
  allNodeIds.forEach(id => collapsedNodes.add(id));
  render();
}}

function buildTree() {{
  // Build a nested tree from project paths
  const tree = {{}};
  const projectPaths = projects.filter(p => {{
    if (!searchQuery) return true;
    return filterConvs(conversations.filter(c => c.project === p.path)).length > 0;
  }});

  for (const p of projectPaths) {{
    const parts = shortPath(p.path).split('/').filter(Boolean);
    let node = tree;
    for (const part of parts) {{
      if (!node[part]) node[part] = {{ _children: {{}}, _projects: [] }};
      if (part === parts[parts.length - 1]) node[part]._projects.push(p);
      node = node[part]._children;
    }}
  }}
  return tree;
}}

function countTreeConvs(node) {{
  let total = 0;
  for (const p of (node._projects || [])) {{
    total += searchQuery ? filterConvs(conversations.filter(c => c.project === p.path)).length : p.conversations;
  }}
  for (const [k, child] of Object.entries(node._children || {{}})) {{
    total += countTreeConvs(child);
  }}
  return total;
}}

function renderTreeNode(name, node, depth, fullPath) {{
  const hasChildren = Object.keys(node._children).length > 0;
  const hasProjects = node._projects.length > 0;
  const count = countTreeConvs(node);
  const nodeId = fullPath;
  const isCollapsed = collapsedNodes.has(nodeId);
  const isActive = hasProjects && node._projects.some(p => p.path === currentProject);
  const indent = depth * 18;

  const toggle = hasChildren ? (isCollapsed ? '\u25b8' : '\u25be') : '';
  const icon = '&#128193;';

  let html = '<div class="tree-node">'
    + '<div class="tree-row' + (isActive ? ' active' : '') + '" style="padding-left:' + (12 + indent) + 'px" data-path="' + esc(fullPath) + '" data-node-id="' + esc(nodeId) + '" data-has-project="' + hasProjects + '">'
    + '<span class="tree-toggle">' + toggle + '</span>'
    + '<span class="tree-icon">' + icon + '</span>'
    + '<span class="tree-name">' + esc(name) + '</span>'
    + (count > 0 ? '<span class="tree-count">' + count + '</span>' : '')
    + '</div>';

  if (hasChildren) {{
    const childKeys = Object.keys(node._children).sort();
    html += '<div class="tree-children' + (isCollapsed ? ' collapsed' : '') + '">';
    childKeys.forEach((key) => {{
      const childPath = fullPath + '/' + key;
      html += renderTreeNode(key, node._children[key], depth + 1, childPath);
    }});
    html += '</div>';
  }}

  html += '</div>';
  return html;
}}

function renderSidebar() {{
  const sb = document.getElementById('sidebar');
  const tree = buildTree();
  allNodeIds = [];
  collectNodeIds(tree, '');
  const rootKeys = Object.keys(tree).sort();

  let html = '<div class="sidebar-header"><span>Projects (' + projects.length + ')</span>'
    + '<div class="tree-controls">'
    + '<button onclick="expandAll()">expand</button>'
    + '<button onclick="collapseAll()">collapse</button>'
    + '</div></div>';
  html += '<div class="tree">';
  rootKeys.forEach((key) => {{
    html += renderTreeNode(key, tree[key], 0, key);
  }});
  html += '</div>';

  sb.innerHTML = html;

  // Bind click events
  // Toggle arrow collapses/expands
  sb.querySelectorAll('.tree-toggle').forEach(tog => {{
    tog.addEventListener('click', (e) => {{
      e.stopPropagation();
      const row = tog.closest('.tree-row');
      const nodeId = row.dataset.nodeId;
      const children = row.parentElement.querySelector('.tree-children');
      if (children) {{
        if (collapsedNodes.has(nodeId)) collapsedNodes.delete(nodeId);
        else collapsedNodes.add(nodeId);
        render();
      }}
    }});
  }});
  // Clicking the row selects the project, or collapses if no project
  sb.querySelectorAll('.tree-row').forEach(el => {{
    el.addEventListener('click', () => {{
      const nodeId = el.dataset.nodeId;
      const hasProject = el.dataset.hasProject === 'true';

      if (hasProject) {{
        let fullPath = nodeId.startsWith('~') ? HOME + nodeId.slice(1) : '/' + nodeId;
        const proj = projects.find(p => p.path === fullPath);
        if (proj) {{ selectProject(proj.path); return; }}
      }}

      // No project — toggle collapse
      const children = el.parentElement.querySelector('.tree-children');
      if (children) {{
        if (collapsedNodes.has(nodeId)) collapsedNodes.delete(nodeId);
        else collapsedNodes.add(nodeId);
        render();
      }}
    }});
  }});
}}

function renderConvCard(c, showProject) {{
  let tags = '';
  if (showProject) tags += '<span class="tag project-tag">' + esc(shortPath(c.project)) + '</span>';
  if (c.git_branch) tags += '<span class="tag branch">' + esc(c.git_branch) + '</span>';
  tags += '<span class="tag msgs">' + c.user_messages + ' msgs</span>';
  tags += '<span class="tag size">' + formatSize(c.size_kb) + '</span>';

  return '<div class="conv-card" data-session="' + c.session_id + '" style="cursor:pointer">'
    + '<div class="top-row">'
    + '<div class="message" title="' + esc(c.first_message || '') + '">' + esc(c.title || c.first_message || '(empty)') + '</div>'
    + '<div class="time">' + relativeTime(c.last_timestamp) + '</div>'
    + '</div>'
    + '<div class="bottom-row">' + tags
    + '<button class="resume-btn" data-cmd="claude --resume ' + c.session_id + '">copy resume cmd</button>'
    + '</div></div>';
}}

function bindCardEvents() {{
  document.querySelectorAll('.resume-btn').forEach(btn => {{
    btn.addEventListener('click', (e) => {{
      e.stopPropagation();
      navigator.clipboard.writeText(btn.dataset.cmd).then(() => {{
        btn.textContent = 'copied!';
        btn.classList.add('copied');
        setTimeout(() => {{ btn.textContent = 'copy resume cmd'; btn.classList.remove('copied'); }}, 1500);
      }});
    }});
  }});
  document.querySelectorAll('.conv-card[data-session]').forEach(card => {{
    card.addEventListener('click', () => openViewer(card.dataset.session));
  }});
}}

function openViewer(sessionId) {{
  const conv = conversations.find(c => c.session_id === sessionId);
  if (!conv) return;
  const overlay = document.getElementById('viewer-overlay');
  const title = document.getElementById('viewer-title');
  const msgs = document.getElementById('viewer-messages');

  title.textContent = (conv.first_message || '(empty)').slice(0, 80);

  let html = '';
  if (!conv.messages || conv.messages.length === 0) {{
    html = '<div class="empty-state"><p>No messages to display</p></div>';
  }} else {{
    for (const m of conv.messages) {{
      html += '<div class="msg ' + m.role + '">'
        + '<div class="msg-role">' + m.role + '</div>'
        + esc(m.text)
        + '</div>';
    }}
  }}
  msgs.innerHTML = html;
  msgs.scrollTop = 0;
  overlay.classList.add('open');
}}

function closeViewer() {{
  document.getElementById('viewer-overlay').classList.remove('open');
}}

function renderProjectView() {{
  const el = document.getElementById('content');
  const convs = currentProject
    ? filterConvs(conversations.filter(c => c.project === currentProject))
    : filterConvs(conversations);
  if (convs.length === 0) {{
    el.innerHTML = '<div class="empty-state"><h2>No conversations found</h2><p>Try a different search or project</p></div>';
    return;
  }}
  el.innerHTML = convs.map(c => renderConvCard(c, !currentProject)).join('');
  bindCardEvents();
}}

function renderTimelineView() {{
  const el = document.getElementById('content');
  const convs = filterConvs(conversations);
  if (convs.length === 0) {{
    el.innerHTML = '<div class="empty-state"><h2>No conversations found</h2></div>';
    return;
  }}
  const groups = {{}};
  for (const c of convs) {{
    const date = c.last_timestamp ? new Date(c.last_timestamp).toLocaleDateString('en-CA') : 'Unknown';
    (groups[date] = groups[date] || []).push(c);
  }}
  let html = '';
  for (const [date, group] of Object.entries(groups)) {{
    html += '<div class="timeline-group">'
      + '<div class="date-header">' + date + ' (' + group.length + ' conversations)</div>'
      + group.map(c => renderConvCard(c, true)).join('')
      + '</div>';
  }}
  el.innerHTML = html;
  bindCardEvents();
}}

function renderBranchView() {{
  const el = document.getElementById('content');
  const convs = currentProject
    ? filterConvs(conversations.filter(c => c.project === currentProject))
    : filterConvs(conversations);
  if (convs.length === 0) {{
    el.innerHTML = '<div class="empty-state"><h2>No conversations found</h2></div>';
    return;
  }}
  const groups = {{}};
  for (const c of convs) {{
    const branch = c.git_branch || 'no branch';
    (groups[branch] = groups[branch] || []).push(c);
  }}
  // Sort branches by most recent activity
  const sorted = Object.entries(groups).sort((a, b) => {{
    const aMax = a[1].reduce((m, c) => c.last_timestamp > m ? c.last_timestamp : m, '');
    const bMax = b[1].reduce((m, c) => c.last_timestamp > m ? c.last_timestamp : m, '');
    return bMax.localeCompare(aMax);
  }});
  let html = '';
  for (const [branch, group] of sorted) {{
    html += '<div class="timeline-group">'
      + '<div class="date-header"><span class="tag branch" style="font-size:12px;padding:2px 12px">' + esc(branch) + '</span> (' + group.length + ')</div>'
      + group.map(c => renderConvCard(c, true)).join('')
      + '</div>';
  }}
  el.innerHTML = html;
  bindCardEvents();
}}

function render() {{
  selectedIndex = -1;
  renderSidebar();
  if (currentView === 'project') renderProjectView();
  else if (currentView === 'timeline') renderTimelineView();
  else renderBranchView();
  const f = filterConvs(conversations);
  document.getElementById('stats').textContent = f.length + ' conversations · ' + projects.length + ' projects';
}}

function selectProject(path) {{
  currentProject = currentProject === path ? null : path;
  render();
}}

function setView(view) {{
  currentView = view;
  document.getElementById('btn-project').classList.toggle('active', view === 'project');
  document.getElementById('btn-timeline').classList.toggle('active', view === 'timeline');
  document.getElementById('btn-branch').classList.toggle('active', view === 'branch');
  if (view !== 'project') currentProject = null;
  render();
}}

let searchTimeout;
document.getElementById('search').addEventListener('input', (e) => {{
  clearTimeout(searchTimeout);
  searchTimeout = setTimeout(() => {{ searchQuery = e.target.value.trim(); render(); }}, 150);
}});

let selectedIndex = -1;

function getVisibleCards() {{
  return Array.from(document.querySelectorAll('.conv-card[data-session]'));
}}

function updateSelection(cards) {{
  cards.forEach((c, i) => c.classList.toggle('selected', i === selectedIndex));
  if (selectedIndex >= 0 && selectedIndex < cards.length) {{
    cards[selectedIndex].scrollIntoView({{ block: 'nearest' }});
  }}
}}

document.addEventListener('keydown', (e) => {{
  const inInput = document.activeElement.tagName === 'INPUT';
  const viewerOpen = document.getElementById('viewer-overlay').classList.contains('open');

  if (e.key === '/' && !inInput) {{
    e.preventDefault();
    document.getElementById('search').focus();
    return;
  }}

  if (e.key === 'Escape') {{
    if (viewerOpen) {{ closeViewer(); }}
    else if (inInput) {{ document.getElementById('search').value = ''; searchQuery = ''; document.getElementById('search').blur(); render(); }}
    else {{ selectedIndex = -1; updateSelection(getVisibleCards()); }}
    return;
  }}

  if (inInput || viewerOpen) return;

  const cards = getVisibleCards();
  if (!cards.length) return;

  if (e.key === 'j' || e.key === 'ArrowDown') {{
    e.preventDefault();
    selectedIndex = Math.min(selectedIndex + 1, cards.length - 1);
    updateSelection(cards);
  }}
  if (e.key === 'k' || e.key === 'ArrowUp') {{
    e.preventDefault();
    selectedIndex = Math.max(selectedIndex - 1, 0);
    updateSelection(cards);
  }}
  if (e.key === 'Enter' && selectedIndex >= 0) {{
    e.preventDefault();
    const sid = cards[selectedIndex].dataset.session;
    if (sid) openViewer(sid);
  }}
}});

// Theme
function getTheme() {{
  return localStorage.getItem('ccc-theme') || 'dark';
}}
function applyTheme(t) {{
  document.documentElement.setAttribute('data-theme', t);
  document.getElementById('theme-btn').innerHTML = t === 'dark' ? '&#9728;&#65039;' : '&#127769;';
}}
function toggleTheme() {{
  const t = getTheme() === 'dark' ? 'light' : 'dark';
  localStorage.setItem('ccc-theme', t);
  applyTheme(t);
}}
applyTheme(getTheme());

render();
</script>
</body>
</html>"""


def main():
    parser = argparse.ArgumentParser(
        prog="ccc",
        description="claude-code-colorful — a colorful conversation history browser for Claude Code",
    )
    parser.add_argument("--no-open", action="store_true", help="generate without opening browser")
    parser.add_argument("-o", "--output", help="write HTML to this path instead of a temp file")
    parser.add_argument("-a", "--all", action="store_true", help="show all projects (default: filter to current directory)")
    parser.add_argument("-s", "--serve", nargs="?", const=8080, type=int, metavar="PORT", help="start a local server (default port: 8080)")
    args = parser.parse_args()

    if args.serve:
        return _serve(args.serve, show_all=args.all)

    html = _build_html(show_all=args.all)

    if args.output:
        out_path = os.path.abspath(args.output)
    else:
        out_path = os.path.join(str(Path.home()), "claude-history.html")

    with open(out_path, "w") as f:
        f.write(html)

    print(f"Generated: {out_path}", file=sys.stderr)

    if not args.no_open:
        webbrowser.open(f"file://{out_path}")


def _build_html(show_all: bool = False) -> str:
    """Scan conversations and generate HTML."""
    print("Scanning conversations...", file=sys.stderr)
    projects = scan_all_conversations()

    if not show_all:
        cwd = os.getcwd()
        # Match projects under cwd, or the exact cwd project
        filtered = {p: c for p, c in projects.items() if p.startswith(cwd) or p == cwd}
        if filtered:
            projects = filtered
            print(f"Filtered to {cwd}", file=sys.stderr)
        else:
            print(f"No conversations found for {cwd}", file=sys.stderr)
            print("Use --all to show all projects", file=sys.stderr)
            return generate_html({})

    total_convs = sum(len(v) for v in projects.values())
    print(f"Found {total_convs} conversations across {len(projects)} projects", file=sys.stderr)
    return generate_html(projects)


def _serve(port: int, show_all: bool = False):
    """Start a local HTTP server that regenerates HTML on each request."""
    from http.server import HTTPServer, BaseHTTPRequestHandler

    class Handler(BaseHTTPRequestHandler):
        def do_GET(self):
            html = _build_html(show_all=show_all)
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(html.encode("utf-8"))

        def log_message(self, fmt, *a):
            print(fmt % a, file=sys.stderr)

    url = f"http://localhost:{port}"
    print(f"Serving on {url} (Ctrl+C to stop)", file=sys.stderr)
    webbrowser.open(url)
    try:
        HTTPServer(("", port), Handler).serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.", file=sys.stderr)


if __name__ == "__main__":
    main()
